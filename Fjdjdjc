<template>
  <div class="range-slider" @pointerdown.prevent="">
    <div class="track" ref="track">
      <!-- 선택된 구간 -->
      <div
        class="range"
        :style="{ left: rangeLeft + '%', width: rangeWidth + '%' }"
      ></div>

      <!-- 최소 핸들 -->
      <button
        class="thumb thumb-left"
        :style="{ left: leftPercent + '%' }"
        ref="leftThumb"
        role="slider"
        :aria-valuemin="min"
        :aria-valuemax="max"
        :aria-valuenow="leftValue"
        aria-label="Minimum value"
        @pointerdown="startDrag('min', $event)"
        @keydown="onKeydown('min', $event)"
      ></button>

      <!-- 최대 핸들 -->
      <button
        class="thumb thumb-right"
        :style="{ left: rightPercent + '%' }"
        ref="rightThumb"
        role="slider"
        :aria-valuemin="min"
        :aria-valuemax="max"
        :aria-valuenow="rightValue"
        aria-label="Maximum value"
        @pointerdown="startDrag('max', $event)"
        @keydown="onKeydown('max', $event)"
      ></button>
    </div>

    <div class="labels">
      <div class="label">Min: {{ leftValue }}</div>
      <div class="label">Max: {{ rightValue }}</div>
    </div>
  </div>
</template>

<script>
export default {
  name: "RangeSlider",

  props: {
    modelValue: Array,
    min: { type: Number, default: 0 },
    max: { type: Number, default: 100 },
    step: { type: Number, default: 1 }
  },

  data() {
    return {
      leftValue: this.modelValue?.[0] ?? this.min,
      rightValue: this.modelValue?.[1] ?? this.max,
      active: null
    };
  },

  watch: {
    modelValue: {
      immediate: true,
      handler(v) {
        if (!v) return;
        this.leftValue = this.clamp(v[0], this.min, this.max);
        this.rightValue = this.clamp(v[1], this.min, this.max);
      }
    },

    leftValue() {
      this.emitValues();
    },
    rightValue() {
      this.emitValues();
    }
  },

  computed: {
    leftPercent() {
      return this.valueToPercent(this.leftValue);
    },
    rightPercent() {
      return this.valueToPercent(this.rightValue);
    },
    rangeLeft() {
      return this.leftPercent;
    },
    rangeWidth() {
      return this.rightPercent - this.leftPercent;
    }
  },

  methods: {
    /* -------------------
       Drag Logic
    ------------------- */
    startDrag(which, ev) {
      this.active = which;
      ev.target.setPointerCapture(ev.pointerId);

      window.addEventListener("pointermove", this.onMove);
      window.addEventListener("pointerup", this.onUp);
    },

    onMove(ev) {
      if (!this.active || !this.$refs.track) return;

      const rect = this.$refs.track.getBoundingClientRect();
      const pct = ((ev.clientX - rect.left) / rect.width) * 100;
      const value = this.percentToValue(pct);

      if (this.active === "min") {
        this.leftValue = Math.min(value, this.rightValue);
      } else {
        this.rightValue = Math.max(value, this.leftValue);
      }
    },

    onUp() {
      window.removeEventListener("pointermove", this.onMove);
      window.removeEventListener("pointerup", this.onUp);
      this.active = null;
    },

    /* -------------------
       Keyboard Accessible
    ------------------- */
    onKeydown(which, ev) {
      let delta = 0;
      if (ev.key === "ArrowLeft" || ev.key === "ArrowDown") delta = -this.step;
      if (ev.key === "ArrowRight" || ev.key === "ArrowUp") delta = this.step;
      if (ev.key === "PageUp") delta = this.step * 10;
      if (ev.key === "PageDown") delta = -this.step * 10;

      if (!delta) return;

      ev.preventDefault();

      if (which === "min") {
        this.leftValue = this.clamp(this.leftValue + delta, this.min, this.rightValue);
      } else {
        this.rightValue = this.clamp(this.rightValue + delta, this.leftValue, this.max);
      }
    },

    /* -------------------
       Utils
    ------------------- */
    emitValues() {
      if (this.leftValue > this.rightValue) {
        const a = Math.min(this.leftValue, this.rightValue);
        const b = Math.max(this.leftValue, this.rightValue);
        this.leftValue = a;
        this.rightValue = b;
      }
      this.$emit("update:modelValue", [this.leftValue, this.rightValue]);
    },

    clamp(v, min, max) {
      return Math.min(Math.max(v, min), max);
    },

    valueToPercent(v) {
      return ((v - this.min) / (this.max - this.min)) * 100;
    },

    percentToValue(p) {
      const raw = this.min + ((Math.min(Math.max(p, 0), 100) / 100) * (this.max - this.min));
      return Math.round(raw / this.step) * this.step;
    }
  }
};
</script>

<style scoped>
.range-slider {
  width: 100%;
  max-width: 520px;
  user-select: none;
}

.track {
  position: relative;
  height: 10px;
  margin: 16px 0;
  background: #e6e6e6;
  border-radius: 999px;
}

.range {
  position: absolute;
  top: 0;
  bottom: 0;
  border-radius: 999px;
  background: #3b82f6;
}

.thumb {
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: white;
  border: 2px solid #999;
  cursor: grab;
  touch-action: none;
}
.thumb:active {
  cursor: grabbing;
}

.labels {
  display: flex;
  justify-content: space-between;
}
.label {
  padding: 4px 8px;
  background: #f1f1f1;
  border-radius: 4px;
}
</style>
